# ===========================================
# Cally - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Database (SQLite by default, or use PostgreSQL/MySQL connection string)
DATABASE_URL="file:./dev.db"

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_NAME="Cally"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# OAuth Providers (optional)
# ===========================================

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# X (Twitter)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple
APPLE_ID=
APPLE_SECRET=

# ===========================================
# APIs (optional)
# ===========================================

# Calendarific - National holiday data for 230+ countries
# Sign up free: https://calendarific.com
CALENDARIFIC_API_KEY=

# ===========================================
# Email (optional - for notifications/reminders)
# ===========================================

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
