    "packages/*"
  ],
  "scripts": {
    "dev": "bun run client:dev",
    "build": "bun run client:build",
    "start": "bun run client:start",
    "client:dev": "bun --cwd client dev",
    "client:build": "bun --cwd client build",
    "client:start": "bun --cwd client start",
    "client:typecheck": "bun --cwd client typecheck",
    "backend:dev": "bun --cwd backend dev",
    "backend:start": "bun --cwd backend start",
    "backend:typecheck": "bun --cwd backend typecheck",
    "worker:dev": "bun --cwd backend worker:dev",
    "check:architecture": "node scripts/check-client-boundary.mjs",
    "typecheck": "bun run check:architecture && bun run backend:typecheck && bun run client:typecheck"
  },
